NEXT_PUBLIC_APP_NAME=PeripheralsTalk
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Immutable deployed FastAPI backend. The browser never talks to Neon directly.
FASTAPI_BASE_URL=https://peripheralstalk-f4aa79e9.fastapicloud.dev
FASTAPI_API_PREFIX=/api/v1
FASTAPI_REQUEST_TIMEOUT_MS=60000
FASTAPI_AUTH_TIMEOUT_MS=120000

AUTH_COOKIE_NAME=peripheralstalk_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_SECONDS=3600
